# Application
APP_NAME=TaskIntelligence
APP_VERSION=0.1.0
DEBUG=True
SECRET_KEY=your-secret-key-here-change-in-production

# Database
DATABASE_URL=postgresql+asyncpg://taskapp:taskapp@localhost:5432/task_intelligence
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=0

# Redis
REDIS_URL=redis://localhost:6379/0

# Microsoft Azure AD (Personal Account)
MICROSOFT_CLIENT_ID=your-client-id
MICROSOFT_CLIENT_SECRET=your-client-secret
MICROSOFT_TENANT_ID=common
MICROSOFT_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback
MICROSOFT_SCOPES=User.Read,Mail.Read,Calendars.Read,Files.Read.All,Team.ReadBasic.All,Chat.Read,OnlineMeetings.Read

# Claude AI
ANTHROPIC_API_KEY=your-anthropic-api-key

# Celery
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/0
CELERY_TASK_INTERVAL_HOURS=2

# CORS
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173"]

# JWT
JWT_SECRET_KEY=your-jwt-secret-key
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=10080

# Learning System
LEARNING_ENABLED=True
LEARNING_BATCH_SIZE=10
LEARNING_UPDATE_INTERVAL_HOURS=24

# Logging
LOG_LEVEL=INFO
LOG_FORMAT=json
